// ─── LOAD BARRIO FROM URL ─────────────────────────────────────────────────────
const params = new URLSearchParams(window.location.search);
const nombreParam = params.get('nombre') || 'El Poblado';
const B = BARRIOS_DB[nombreParam] || BARRIOS_DB['El Poblado'];
const nombre = nombreParam in BARRIOS_DB ? nombreParam : 'El Poblado';

// Fill header
document.title = `BarrioVoz – ${nombre}`;
document.getElementById('bc-name').textContent = nombre;
document.getElementById('b-name').textContent = nombre;
document.getElementById('b-commune').textContent = B.commune;
document.getElementById('b-reviews').textContent = `💬 ${B.reviews} opiniones`;
document.getElementById('score-bv').textContent = B.bvScore.toFixed(1);
document.getElementById('score-us').textContent = B.userScore.toFixed(1);

// Terrain badge
const terrainEl = document.getElementById('b-terrain');
const tLabels = { plano:'🟢 Terreno plano', moderado:'🟡 Terreno moderado', empinado:'🔴 Terreno empinado' };
terrainEl.textContent = tLabels[B.terreno] || B.terreno;
terrainEl.className = `terrain-badge terrain-${B.terreno}`;

// Tags
document.getElementById('b-tags').innerHTML = B.tags.map(t=>`<span class="tag">${t}</span>`).join('');

// ─── MAP ─────────────────────────────────────────────────────────────────────
const map = L.map('barrio-map', { zoomControl:true, scrollWheelZoom:false })
  .setView([B.lat, B.lng], 15);

L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
  attribution:'&copy; OpenStreetMap &copy; CartoDB', maxZoom:19
}).addTo(map);

// Highlight circle
const scoreAvg = (B.bvScore + B.userScore) / 2;
const mapColor = scoreAvg>=4?'#4caf82':scoreAvg>=2.5?'#e8c547':'#e05c5c';
L.circle([B.lat, B.lng], {
  radius:600, color:mapColor, fillColor:mapColor, fillOpacity:0.25, weight:2
}).addTo(map).bindPopup(`<b style="color:${mapColor}">${nombre}</b><br>${B.commune}`).openPopup();

// ─── RATINGS ─────────────────────────────────────────────────────────────────
const ratings = [
  { label:'🛡️ Seguridad',         val:B.seguridad },
  { label:'🚌 Transporte público', val:B.transporte },
  { label:'🎓 Colegios y educ.',   val:B.colegios },
  { label:'🏥 Salud y hospitales', val:B.hospitales },
  { label:'🎭 Vida de barrio',     val:B.vida },
  { label:'🔇 Nivel de ruido',     val:B.ruido, invert:true },
  { label:'🌿 Zonas verdes',       val:B.verde },
];

function rClass(v, invert) {
  const eff = invert ? (5-v) : v;
  return eff>=4?'good':eff>=2.5?'mid':'low';
}
function rColor(v, invert) {
  const eff = invert ? (5-v) : v;
  return eff>=4?'var(--green)':eff>=2.5?'var(--accent)':'var(--red)';
}

document.getElementById('ratings-grid').innerHTML = ratings.map(r => `
  <div class="rating-row">
    <div class="rating-header">
      <span class="r-label">${r.label}</span>
      <span class="r-score ${rClass(r.val,r.invert)}">${r.val.toFixed(1)} / 5</span>
    </div>
    <div class="bar-bg">
      <div class="bar-fill" style="width:${r.val/5*100}%;background:${rColor(r.val,r.invert)}"></div>
    </div>
  </div>
`).join('');

// ─── SCORE SUMMARY SIDEBAR ───────────────────────────────────────────────────
document.getElementById('score-summary-rows').innerHTML = [
  { name:'BarrioVoz', val:B.bvScore, color:'var(--accent)' },
  { name:'Usuarios',  val:B.userScore, color:'var(--green)' },
  ...ratings.map(r=>({ name:r.label, val:r.val, color:rColor(r.val,r.invert) }))
].map(r=>`
  <div class="ss-row">
    <span class="ss-name">${r.name}</span>
    <span class="ss-val" style="color:${r.color}">★ ${r.val.toFixed(1)}</span>
  </div>
`).join('');

