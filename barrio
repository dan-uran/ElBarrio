<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>BarrioVoz – Barrio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;1,9..144,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
  <style>
    :root {
      --bg: #0d1117; --surface: #161b22; --surface2: #1e2530;
      --accent: #e8c547; --text: #e8e8e0; --muted: #8b8f96;
      --border: #2a3040; --green: #4caf82; --red: #e05c5c;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    body { background:var(--bg); color:var(--text); font-family:'DM Sans',sans-serif; }

    /* NAV */
    nav {
      position:fixed; top:0; left:0; right:0; z-index:1000;
      display:flex; align-items:center; justify-content:space-between;
      padding:18px 40px;
      background:rgba(13,17,23,0.9); backdrop-filter:blur(12px);
      border-bottom:1px solid var(--border);
    }
    .logo { font-family:'Fraunces',serif; font-size:1.4rem; font-weight:700; color:var(--accent); text-decoration:none; }
    .logo span { color:var(--text); }
    .back-btn {
      display:flex; align-items:center; gap:8px;
      color:var(--muted); text-decoration:none; font-size:0.88rem;
      border:1px solid var(--border); border-radius:6px; padding:7px 14px;
      transition:all 0.2s;
    }
    .back-btn:hover { color:var(--text); border-color:var(--text); }
    .nav-btn {
      background:var(--accent); color:#0d1117; border:none;
      padding:9px 20px; border-radius:6px;
      font-family:'DM Sans',sans-serif; font-size:0.85rem; font-weight:500;
      cursor:pointer;
    }

    /* HERO BARRIO */
    .barrio-hero {
      padding:100px 40px 0;
      max-width:1300px; margin:0 auto;
    }
    .breadcrumb {
      font-size:0.78rem; color:var(--muted); margin-bottom:16px;
    }
    .breadcrumb a { color:var(--accent); text-decoration:none; }
    .barrio-hero-inner {
      display:grid; grid-template-columns:1fr auto;
      align-items:start; gap:40px; margin-bottom:40px;
    }
    .barrio-name {
      font-family:'Fraunces',serif;
      font-size:clamp(2.5rem,5vw,4rem);
      font-weight:700; letter-spacing:-1.5px;
      line-height:1.05;
    }
    .barrio-commune {
      font-size:0.88rem; color:var(--muted);
      text-transform:uppercase; letter-spacing:0.08em; margin-bottom:10px;
    }
    .barrio-tags { display:flex; gap:8px; flex-wrap:wrap; margin-top:14px; }
    .tag {
      background:rgba(255,255,255,0.05); border:1px solid var(--border);
      border-radius:4px; padding:4px 10px; font-size:0.75rem; color:var(--muted);
    }
    .score-badges { display:flex; flex-direction:column; gap:12px; align-items:flex-end; }
    .score-badge {
      background:var(--surface); border:1px solid var(--border);
      border-radius:12px; padding:16px 20px; text-align:center; min-width:120px;
    }
    .score-badge .sb-label { font-size:0.72rem; color:var(--muted); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:6px; }
    .score-badge .sb-num {
      font-family:'Fraunces',serif; font-size:2.4rem; font-weight:700; line-height:1;
    }
    .score-badge .sb-sub { font-size:0.72rem; color:var(--muted); margin-top:4px; }

    /* MAIN GRID */
    .main-grid {
      max-width:1300px; margin:0 auto; padding:0 40px 80px;
      display:grid; grid-template-columns:1fr 360px; gap:32px;
    }
    .left-col { display:flex; flex-direction:column; gap:28px; }
    .right-col { display:flex; flex-direction:column; gap:24px; }

    /* CARDS */
    .panel {
      background:var(--surface); border:1px solid var(--border);
      border-radius:14px; padding:24px;
    }
    .panel-title {
      font-family:'Fraunces',serif; font-size:1.15rem; font-weight:700;
      margin-bottom:20px; display:flex; align-items:center; gap:10px;
    }
    .panel-title span { font-size:1.2rem; }

    /* MAP */
    #barrio-map { height:320px; border-radius:10px; overflow:hidden; }

    /* RATINGS */
    .ratings-grid { display:flex; flex-direction:column; gap:14px; }
    .rating-row { display:flex; flex-direction:column; gap:6px; }
    .rating-header {
      display:flex; justify-content:space-between; align-items:center;
      font-size:0.88rem;
    }
    .rating-header .r-label { color:var(--text); }
    .rating-header .r-score { font-weight:600; }
    .r-score.good { color:var(--green); }
    .r-score.mid  { color:var(--accent); }
    .r-score.low  { color:var(--red); }
    .bar-bg { background:var(--surface2); border-radius:4px; height:8px; }
    .bar-fill { height:100%; border-radius:4px; transition:width 1s ease; }

    /* PRACTICAL INFO */
    .info-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
    .info-item {
      background:var(--surface2); border:1px solid var(--border);
      border-radius:10px; padding:14px;
    }
    .info-item .ii-icon { font-size:1.4rem; margin-bottom:6px; }
    .info-item .ii-label { font-size:0.72rem; color:var(--muted); text-transform:uppercase; letter-spacing:0.05em; }
    .info-item .ii-value { font-size:0.95rem; font-weight:500; margin-top:2px; }
    .info-item .ii-detail { font-size:0.75rem; color:var(--muted); margin-top:3px; }

    /* PRICES */
    .price-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
    .price-card {
      background:var(--surface2); border:1px solid var(--border);
      border-radius:10px; padding:18px; text-align:center;
    }
    .price-card .pc-type { font-size:0.75rem; color:var(--muted); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:8px; }
    .price-card .pc-range { font-family:'Fraunces',serif; font-size:1.3rem; color:var(--accent); font-weight:700; }
    .price-card .pc-unit { font-size:0.72rem; color:var(--muted); margin-top:4px; }
    .price-card .pc-trend { font-size:0.75rem; margin-top:8px; padding:3px 8px; border-radius:4px; display:inline-block; }
    .trend-up { background:rgba(76,175,130,0.12); color:var(--green); }
    .trend-down { background:rgba(224,92,92,0.12); color:var(--red); }

    /* NEARBY */
    .nearby-list { display:flex; flex-direction:column; gap:10px; }
    .nearby-item {
      display:flex; align-items:center; justify-content:space-between;
      background:var(--surface2); border-radius:8px; padding:12px 14px;
      font-size:0.85rem;
    }
    .nearby-item .ni-left { display:flex; align-items:center; gap:10px; }
    .nearby-item .ni-icon { font-size:1.1rem; }
    .nearby-item .ni-name { font-weight:500; }
    .nearby-item .ni-type { font-size:0.72rem; color:var(--muted); }
    .nearby-item .ni-dist { color:var(--accent); font-size:0.8rem; font-weight:500; }

    /* SCORE SUMMARY SIDEBAR */
    .score-summary {
      background:var(--surface); border:1px solid var(--border);
      border-radius:14px; padding:20px;
    }
    .ss-title { font-size:0.78rem; color:var(--muted); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:16px; }
    .ss-row {
      display:flex; align-items:center; justify-content:space-between;
      padding:8px 0; border-bottom:1px solid var(--border); font-size:0.85rem;
    }
    .ss-row:last-child { border:none; }
    .ss-row .ss-name { color:var(--muted); }
    .ss-row .ss-val { font-weight:600; }

    /* SHARE / CTA */
    .cta-panel {
      background:linear-gradient(135deg,rgba(232,197,71,0.12),rgba(245,131,42,0.08));
      border:1px solid rgba(232,197,71,0.25); border-radius:14px; padding:22px;
      text-align:center;
    }
    .cta-panel h4 { font-family:'Fraunces',serif; font-size:1.1rem; margin-bottom:8px; }
    .cta-panel p { font-size:0.82rem; color:var(--muted); margin-bottom:16px; line-height:1.5; }
    .cta-btn {
      display:block; width:100%;
      background:var(--accent); color:#0d1117; border:none;
      padding:12px; border-radius:8px;
      font-family:'DM Sans',sans-serif; font-size:0.9rem; font-weight:600;
      cursor:pointer; text-decoration:none; text-align:center;
      transition:opacity 0.2s;
    }
    .cta-btn:hover { opacity:0.85; }
    .cta-btn-ghost {
      display:block; width:100%; margin-top:8px;
      background:none; color:var(--muted); border:1px solid var(--border);
      padding:10px; border-radius:8px;
      font-family:'DM Sans',sans-serif; font-size:0.85rem;
      cursor:pointer; text-decoration:none; text-align:center;
      transition:all 0.2s;
    }
    .cta-btn-ghost:hover { border-color:var(--text); color:var(--text); }

    /* TERRAIN BADGE */
    .terrain-badge {
      display:inline-flex; align-items:center; gap:6px;
      padding:5px 12px; border-radius:20px; font-size:0.8rem; font-weight:500;
    }
    .terrain-plano    { background:rgba(76,175,130,0.12); color:var(--green); border:1px solid rgba(76,175,130,0.3); }
    .terrain-moderado { background:rgba(232,197,71,0.12); color:var(--accent); border:1px solid rgba(232,197,71,0.3); }
    .terrain-empinado { background:rgba(224,92,92,0.12);  color:var(--red);    border:1px solid rgba(224,92,92,0.3); }

    /* LEAFLET DARK */
    .leaflet-popup-content-wrapper {
      background:var(--surface2)!important; border:1px solid var(--border)!important;
      border-radius:10px!important; color:var(--text)!important;
    }
    .leaflet-popup-tip { background:var(--surface2)!important; }

    @media(max-width:900px) {
      .main-grid { grid-template-columns:1fr; }
      .barrio-hero-inner { grid-template-columns:1fr; }
      .score-badges { flex-direction:row; align-items:flex-start; }
      nav .nav-btn { display:none; }
      .main-grid { padding:0 20px 60px; }
      .barrio-hero { padding:90px 20px 0; }
    }
  </style>
</head>
